# Application
PORT=3000
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET=replace-with-a-strong-access-secret-min-16-chars
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret-min-16-chars
JWT_ISSUER=tasks-manager-auth
JWT_AUDIENCE=tasks-manager-api

# Persistence driver: in-memory | typeorm | prisma
PERSISTENCE_DRIVER=in-memory

# API docs exposure (recommended false in production)
SWAGGER_ENABLED=true

# Database URL required when PERSISTENCE_DRIVER=typeorm or prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tasks_manager
